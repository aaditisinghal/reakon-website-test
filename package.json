{
  "name": "reakon-website",
  "version": "1.0.0",
  "scripts": {
    "client": "cd client && npm start",
    "server": "cd server && node index.js",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "install-all": "npm install concurrently && cd client && npm install && cd ../server && npm install"
  },
  "dependencies": {
    "concurrently": "^8.2.0"
  }
}
